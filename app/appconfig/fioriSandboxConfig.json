{
  "services": {
    "LaunchPage": {
      "adapter": {
        "config": {
          "groups": [
            {
              "id": "SalesOrders",
              "title": "Sales Orders",
              "isPreset": true,
              "isVisible": true,
              "isGroupLocked": false,
              "tiles": [
                {
                  "id": "BrowseOrders",
                  "tileType": "sap.ushell.ui.tile.StaticTile",
                  "properties": {
                    "title": "Browse Sales Orders",
                    "targetURL": "#SalesOrder-display"
                  }
                },
                {
                  "id": "BrowseProductCategories",
                  "tileType": "sap.ushell.ui.tile.StaticTile",
                  "properties": {
                    "title": "Product Categories",
                    "targetURL": "#ProductCategory-display"
                  }
                }
              ]
            },
            {
              "id": "Administration",
              "title": "Administration",
              "isPreset": true,
              "isVisible": true,
              "isGroupLocked": false,
              "tiles": [
                {
                  "id": "ManageOrders",
                  "tileType": "sap.ushell.ui.tile.StaticTile",
                  "properties": {
                    "title": "Manage Sales Orders",
                    "targetURL": "#SalesOrder-manage"
                  }
                },
                {
                  "id": "ManageCustomers",
                  "tileType": "sap.ushell.ui.tile.StaticTile",
                  "properties": {
                    "title": "Manage Customers",
                    "targetURL": "#Customer-manage"
                  }
                }
              ]
            }
          ]
        }
      }
    },
    "NavTargetResolution": {
      "config": {
        "enableClientSideTargetResolution": true
      }
    },
    "ClientSideTargetResolution": {
      "adapter": {
        "config": {
          "inbounds": {
            "BrowseOrders": {
              "semanticObject": "SalesOrder",
              "action": "display",
              "title": "Browse Sales Orders",
              "signature": {
                "parameters": {
                  "SalesOrders.ID": {
                    "renameTo": "ID"
                  }
                },
                "additionalParameters": "ignored"
              },
              "resolutionResult": {
                "applicationType": "SAPUI5",
                "additionalInformation": "SAPUI5.Component=cap-sample.browse-orders",
                "url": "/browse-orders/webapp"
              }
            },
            "ManageCustomers": {
              "semanticObject": "Customer",
              "action": "manage",
              "title": "Manage Customers",
              "signature": {
                "parameters": {
                  "SalesOrders.customer.ID": {
                    "renameTo": "ID"
                  }
                },
                "additionalParameters": "ignored"
              },
              "resolutionResult": {
                "applicationType": "SAPUI5",
                "additionalInformation": "SAPUI5.Component=cap-sample.manage-customers",
                "url": "/manage-customers/webapp"
              }
            },
            "BrowseProductCategories": {
              "semanticObject": "ProductCategory",
              "action": "display",
              "title": "Browse Product Categories",
              "signature": {
                "parameters": {
                  "ProductCategory.ID": {
                    "renameTo": "ID"
                  }
                },
                "additionalParameters": "ignored"
              },
              "resolutionResult": {
                "applicationType": "SAPUI5",
                "additionalInformation": "SAPUI5.Component=cap-sample.product-categories",
                "url": "/product-categories/webapp"
              }
            },
            "ManageOrders": {
              "semanticObject": "SalesOrder",
              "action": "manage",
              "title": "Manage Sales Orders",
              "signature": {
                "parameters": {},
                "additionalParameters": "allowed"
              },
              "resolutionResult": {
                "applicationType": "SAPUI5",
                "additionalInformation": "SAPUI5.Component=cap-sample.manage-orders",
                "url": "/manage-orders/webapp"
              }
            }
          }
        }
      }
    }
  }
}
