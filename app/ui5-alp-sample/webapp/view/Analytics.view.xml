<mvc:View
	controllerName="ui5alpsample.controller.Analytics"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:f="sap.f"
	xmlns:l="sap.ui.layout"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:viz="sap.viz.ui5.controls"
	xmlns:vizData="sap.viz.ui5.data">

	<f:DynamicPage id="page" headerExpanded="true" toggleHeaderOnTitleClick="true">
		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="{i18n>analyticsTitle}" level="H2"/>
				</f:heading>
				<f:expandedContent>
					<Label text="{i18n>appDescription}"/>
				</f:expandedContent>
			</f:DynamicPageTitle>
		</f:title>

		<f:header>
			<f:DynamicPageHeader pinnable="true">
				<l:Grid defaultSpan="L4 M6 S12" hSpacing="2">
					<VBox>
						<Label text="{i18n>kpiTotalGross}"/>
						<ObjectNumber
							number="{ path: 'alp>/kpi/totalGross', formatter: '.formatNumber' }"
							unit="{alp>/kpi/currency}"
							emphasized="true"
							core:require="{ NumberFormat: 'sap/ui/core/format/NumberFormat' }"/>
					</VBox>
					<VBox>
						<Label text="{i18n>kpiAvgGross}"/>
						<ObjectNumber
							number="{ path: 'alp>/kpi/avgGross', formatter: '.formatNumber' }"
							unit="{alp>/kpi/currency}"/>
					</VBox>
					<VBox>
						<Label text="{i18n>kpiOrderCount}"/>
						<ObjectNumber number="{alp>/kpi/orderCount}"/>
					</VBox>
				</l:Grid>
				<HBox alignItems="End" wrap="Wrap" class="sapUiSmallMarginTop">
					<VBox class="sapUiSmallMarginEnd">
						<Label text="{i18n>filterStatus}"/>
						<ComboBox width="14rem" selectionChange=".onStatusChange">
							<core:Item key="" text="(All)"/>
							<core:Item key="New" text="New"/>
							<core:Item key="InProgress" text="In Progress"/>
							<core:Item key="Shipped" text="Shipped"/>
							<core:Item key="Completed" text="Completed"/>
							<core:Item key="Cancelled" text="Cancelled"/>
						</ComboBox>
					</VBox>
					<VBox class="sapUiSmallMarginEnd">
						<Label text="{i18n>filterCustomer}"/>
						<ComboBox
							width="16rem"
							items="{ path: '/ListOfOrders', parameters: { $select: 'customer_ID,customerName', $orderby: 'customerName' } }"
							selectionChange=".onCustomerChange">
							<core:Item key="{customer_ID}" text="{customerName}"/>
						</ComboBox>
					</VBox>
					<VBox class="sapUiSmallMarginEnd">
						<Label text="{i18n>chartType}"/>
						<Select width="10rem" change=".onChartTypeChange">
							<core:Item key="column" text="Column"/>
							<core:Item key="bar" text="Bar"/>
							<core:Item key="donut" text="Donut (by country)"/>
						</Select>
					</VBox>
					<VBox>
						<Label text=" "/>
						<Button text="{i18n>btnGo}" type="Emphasized" press=".onGo"/>
					</VBox>
				</HBox>
			</f:DynamicPageHeader>
		</f:header>

		<f:content>
			<VBox>
				<Panel headerText="{i18n>chartTitle}" expandable="false">
					<viz:VizFrame
						id="vizFrame"
						width="100%"
						height="320px"
						uiConfig="{applicationSet:'fiori'}"
						vizType="{= ${alp>/chartType} === 'donut' ? 'donut' : ${alp>/chartType} === 'bar' ? 'bar' : 'column' }">
						<viz:dataset>
							<vizData:FlattenedDataset data="{alp>/chart/rows}">
								<vizData:dimensions>
									<vizData:DimensionDefinition name="Dim" value="{alp>dim}"/>
								</vizData:dimensions>
								<vizData:measures>
									<vizData:MeasureDefinition name="GrossAmount" value="{alp>value}"/>
								</vizData:measures>
							</vizData:FlattenedDataset>
						</viz:dataset>
					</viz:VizFrame>
				</Panel>

				<Table
					id="ordersTable"
					inset="false"
					growing="true"
					growingThreshold="20"
					items="{
						path: '/ListOfOrders',
						parameters: { $expand: 'customer,salesOrg,currency', $count: true }
					}"
					mode="SingleSelectMaster"
					itemPress=".onItemPress">
					<headerToolbar>
						<OverflowToolbar>
							<Title text="{i18n>tableTitle}" level="H3"/>
							<ToolbarSpacer/>
						</OverflowToolbar>
					</headerToolbar>
					<columns>
						<Column><Text text="{i18n>columnOrderNo}"/></Column>
						<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>columnCustomer}"/></Column>
						<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>columnSalesOrg}"/></Column>
						<Column><Text text="{i18n>columnStatus}"/></Column>
						<Column hAlign="End"><Text text="{i18n>columnAmount}"/></Column>
					</columns>
					<items>
						<ColumnListItem
							type="Navigation"
							core:require="{ Currency: 'sap/ui/model/odata/type/Currency' }">
							<cells>
								<ObjectIdentifier title="{orderNo}"/>
								<Text text="{customer/name}"/>
								<Text text="{salesOrg/name}"/>
								<ObjectStatus
									text="{status}"
									state="{= ${statusCriticality} === 1 ? 'Error' : ${statusCriticality} === 2 ? 'Warning' : 'Success' }"/>
								<ObjectNumber
									number="{ parts:[{path:'grossAmount'},{path:'currency_code'}], type:'sap.ui.model.odata.type.Currency', formatOptions:{showMeasure:false} }"
									unit="{currency_code}"/>
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</VBox>
		</f:content>
	</f:DynamicPage>
</mvc:View>
