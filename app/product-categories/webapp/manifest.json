{
  "_version": "1.8.0",
  "sap.app": {
    "id": "cap-sample.product-categories",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "AdminService": {
        "uri": "odata/v4/admin/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "ProductCategory-display": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "title": "{{appTitle}}",
          "subTitle": "{{appSubTitle}}",
          "semanticObject": "ProductCategory",
          "action": "display"
        }
      }
    },
    "i18n": "i18n/i18n.properties"
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.fe.templates": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      },
      "": {
        "dataSource": "AdminService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ProductCategoriesList",
          "target": "ProductCategoriesList"
        },
        {
          "pattern": "ProductCategories({key}):?query:",
          "name": "ProductCategoriesDetails",
          "target": "ProductCategoriesDetails"
        }
      ],
      "targets": {
        "ProductCategoriesList": {
          "type": "Component",
          "id": "ProductCategoriesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/ProductCategories",
              "liveMode": true,
              "navigation": {
                "ProductCategories": {
                  "detail": {
                    "route": "ProductCategoriesDetails"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "hierarchyQualifier": "ProductCategoriesHierarchy",
                    "type": "TreeTable"
                  }
                }
              }
            }
          }
        },
        "ProductCategoriesDetails": {
          "type": "Component",
          "id": "ProductCategoriesDetails",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "contextPath": "/ProductCategories"
            }
          }
        }
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
