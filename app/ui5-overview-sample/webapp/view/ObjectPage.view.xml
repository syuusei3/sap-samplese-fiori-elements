<mvc:View
	controllerName="ui5overviewsample.controller.ObjectPage"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:uxap="sap.uxap"
	xmlns:layout="sap.ui.layout"
	xmlns:form="sap.ui.layout.form"
	xmlns:core="sap.ui.core">

	<Page
		id="objectPage"
		showHeader="true"
		showNavButton="true"
		navButtonPress=".onNavBack"
		title="{i18n>objectHeaderType}: {orderNo}">
		<content>
			<uxap:ObjectPageLayout id="ObjectPageLayout" showTitleInHeaderContent="true" upperCaseAnchorBar="false">
				<uxap:headerTitle>
					<uxap:ObjectPageDynamicHeaderTitle>
						<uxap:expandedHeading><Title text="{orderNo}" wrapping="true" level="H2"/></uxap:expandedHeading>
						<uxap:snappedHeading><Title text="{orderNo}" wrapping="true" level="H2"/></uxap:snappedHeading>
						<uxap:expandedContent><Text text="{customerName}"/></uxap:expandedContent>
					</uxap:ObjectPageDynamicHeaderTitle>
				</uxap:headerTitle>
				<uxap:headerContent>
					<layout:VerticalLayout>
						<ObjectAttribute title="Customer" text="{customerName}"/>
						<ObjectAttribute title="Sales Org" text="{salesOrgName}"/>
					</layout:VerticalLayout>
					<layout:VerticalLayout>
						<ObjectStatus
							title="Status"
							text="{status}"
							state="{= ${status} === 'Cancelled' ? 'Error' : (${status} === 'New' || ${status} === 'InProgress') ? 'Warning' : 'Success' }"/>
						<ObjectNumber
							core:require="{ Currency: 'sap/ui/model/odata/type/Currency' }"
							number="{ parts:[{path:'grossAmount'},{path:'currency_code'}], type:'sap.ui.model.odata.type.Currency', formatOptions:{showMeasure:false} }"
							unit="{currency_code}"
							emphasized="true"/>
					</layout:VerticalLayout>
				</uxap:headerContent>
				<uxap:sections>
					<uxap:ObjectPageSection title="General">
						<uxap:subSections>
							<uxap:ObjectPageSubSection>
								<uxap:blocks>
									<form:Form editable="false">
										<form:title><core:Title text=""/></form:title>
										<form:layout><form:ColumnLayout columnsM="2" columnsL="3"/></form:layout>
										<form:formContainers>
											<form:FormContainer>
												<form:formElements>
													<form:FormElement label="Order No."><form:fields><Text text="{orderNo}"/></form:fields></form:FormElement>
													<form:FormElement label="Order Date"><form:fields><Text text="{orderDate}"/></form:fields></form:FormElement>
													<form:FormElement label="Customer"><form:fields><Text text="{customerName}"/></form:fields></form:FormElement>
													<form:FormElement label="Country"><form:fields><Text text="{customerCountry}"/></form:fields></form:FormElement>
													<form:FormElement label="Sales Org"><form:fields><Text text="{salesOrgName}"/></form:fields></form:FormElement>
												</form:formElements>
											</form:FormContainer>
										</form:formContainers>
									</form:Form>
								</uxap:blocks>
							</uxap:ObjectPageSubSection>
						</uxap:subSections>
					</uxap:ObjectPageSection>
				</uxap:sections>
			</uxap:ObjectPageLayout>
		</content>
	</Page>
</mvc:View>
