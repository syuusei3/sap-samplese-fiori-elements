{
	"_version": "2.0.0",

	"sap.app": {
		"id": "ui5lropsample",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"applicationVersion": {
			"version": "${version}"
		},
		"dataSources": {
			"default": {
				"uri": "/odata/v4/catalog-lrop/",
				"type": "OData",
				"settings": {
					"odataVersion": "4.0"
				}
			}
		},
		"sourceTemplate": {
			"id": "@ui5/mcp-server:ts",
			"version": "0.2.11"
		}
	},

	"sap.ui": {
		"technology": "UI5",
		"icons": {},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},

	"sap.ui5": {
		"rootView": {
			"viewName": "ui5lropsample.view.App",
			"type": "XML",
			"id": "app"
		},

		"dependencies": {
			"minUI5Version": "1.148.1",
			"libs": {
				"sap.ui.core": {},
				"sap.m": {},
				"sap.ui.layout": {},
				"sap.f": {},
				"sap.uxap": {}
			}
		},

		"flexEnabled": false,

		"handleValidation": true,

		"contentDensities": {
			"compact": true,
			"cozy": true
		},

		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "ui5lropsample.i18n.i18n",
					"async": true
				}
			},
			"": {
				"dataSource": "default",
				"settings": {
					"autoExpandSelect": true,
					"earlyRequests": true,
					"operationMode": "Server"
				}
			}
		},

		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"type": "View",
				"viewType": "XML",
				"path": "ui5lropsample.view",
				"controlId": "app",
				"controlAggregation": "pages"
			},
			"routes": [
				{
					"pattern": "",
					"name": "worklist",
					"target": "worklist"
				},
				{
					"pattern": "SalesOrders/{orderId}",
					"name": "object",
					"target": "object"
				}
			],
			"targets": {
				"worklist": {
					"id": "worklist",
					"name": "Worklist"
				},
				"object": {
					"id": "object",
					"name": "ObjectPage"
				}
			}
		}
	}
}
